{
  "name": "investimentos-app",
  "version": "0.1.210",
  "private": true,
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "bash scripts/dev-resilient.sh",
    "dev:raw": "concurrently --kill-others -n \"⚡NEXT\",\"🔌PROXY\" --prefix \"[{name}]\" --prefix-length 10 -c \"bold.blue\",\"bold.magenta\" --timestamp-format \"HH:mm:ss\" \"next dev --turbopack\" \"npx tsx scripts/claude-proxy.ts\" | node scripts/dev-prefix-ruler.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "generate:icons": "node scripts/gerar-icones-pwa.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "proxy": "npx tsx scripts/claude-proxy.ts",
    "db:migrate-blob": "tsx scripts/migrate-blob-to-db.ts",
    "prepare": "husky",
    "desktop:build-main": "tsc -p electron/tsconfig.json",
    "desktop:build-proxy": "tsc --target ES2020 --module commonjs --esModuleInterop --strict --skipLibCheck --outDir electron/dist scripts/claude-proxy.ts",
    "desktop": "npm run desktop:build-main && npm run desktop:build-proxy && ELECTRON_RUN_AS_NODE= npx electron ."
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@neslinesli93/qpdf-wasm": "^0.3.0",
    "@radix-ui/react-label": "^2.1.8",
    "@vercel/blob": "^2.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.563.0",
    "next": "15.5.12",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "pdf-parse": "^2.4.5",
    "radix-ui": "^1.4.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^9.1.0",
    "recharts": "^2.15.4",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "swr": "^2.4.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  }
}
