{
  "name": "investimentos-app",
  "version": "0.1.176",
  "private": true,
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "bash scripts/dev-resilient.sh",
    "dev:raw": "concurrently --kill-others -n \"⚡NEXT\",\"🔌PROXY\" --prefix \"[{name}]\" --prefix-length 10 -c \"bold.blue\",\"bold.magenta\" --timestamp-format \"HH:mm:ss\" \"next dev --turbopack\" \"npx tsx scripts/claude-proxy.ts\" | node scripts/dev-prefix-ruler.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "generate:icons": "node scripts/gerar-icones-pwa.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "proxy": "npx tsx scripts/claude-proxy.ts",
    "db:migrate-blob": "tsx scripts/migrate-blob-to-db.ts",
    "prepare": "husky",
    "desktop:build-main": "tsc -p electron/tsconfig.json",
    "desktop:build-proxy": "tsc --target ES2020 --module commonjs --esModuleInterop --strict --skipLibCheck --outDir electron/dist scripts/claude-proxy.ts",
    "desktop": "npm run desktop:build-main && npm run desktop:build-proxy && ELECTRON_RUN_AS_NODE= npx electron .",
    "desktop:package": "npm run build && npm run desktop:build-main && npm run desktop:build-proxy && electron-builder --mac"
  },
  "build": {
    "appId": "com.fortuna.app",
    "productName": "Fortuna",
    "mac": {
      "target": "dir",
      "icon": "public/icon-512.png"
    },
    "files": [
      "electron/dist/**/*",
      "electron/icons/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".next/static",
        "to": "standalone/.next/static",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public",
        "to": "standalone/public",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "electron/dist/claude-proxy.js",
        "to": "claude-proxy.js"
      },
      {
        "from": ".env.local",
        "to": ".env.local"
      }
    ],
    "directories": {
      "output": "electron-dist"
    }
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@neslinesli93/qpdf-wasm": "^0.3.0",
    "@radix-ui/react-label": "^2.1.8",
    "@vercel/blob": "^2.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.563.0",
    "next": "15.5.12",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "pdf-parse": "^2.4.5",
    "radix-ui": "^1.4.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^9.1.0",
    "recharts": "^2.15.4",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "swr": "^2.4.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.12",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^3.8.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
