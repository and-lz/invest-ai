# ============================================
# Banco de Dados (PostgreSQL via Neon)
# ============================================
# Obter em: https://console.neon.tech
# Branch "main" para producao, branch "dev" para desenvolvimento
DATABASE_URL="postgresql://neondb_owner:xxx@ep-xxx.sa-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ============================================
# Autenticacao (Google OAuth)
# ============================================
# Obter em: https://console.cloud.google.com/apis/credentials
# Redirect URI (dev): http://localhost:3000/api/auth/callback/google
# Redirect URI (prod): https://seu-dominio.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="your-app-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"

# Gerar com: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# ============================================
# Vercel Blob Storage (apenas para PDFs)
# ============================================
# Auto-injetado na Vercel em producao. Opcional localmente (PDFs usam filesystem em dev).
BLOB_READ_WRITE_TOKEN="vercel_blob_xxx"

# ============================================
# Storage local (apenas desenvolvimento, PDFs)
# ============================================
DATA_DIRECTORY="./data"

# ============================================
# AI (Claude Proxy — dev only)
# ============================================
# Local Claude proxy URL (default: http://localhost:3099)
# CLAUDE_PROXY_URL="http://localhost:3099"

# ============================================
# Tavily Web Search (modo mercado no chat)
# ============================================
# Obter em: https://tavily.com — free tier: 1.000 buscas/mes
# Sem essa chave, o modo mercado fica desabilitado silenciosamente
# TAVILY_API_KEY="tvly-xxx"
